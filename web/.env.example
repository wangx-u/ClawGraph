# `mock` 使用内置演示数据；`prod` 优先读取真实 HTTP API，失败后再尝试本地 Store。
NEXT_PUBLIC_DATA_MODE=mock
NEXT_PUBLIC_CLAWGRAPH_API_BASE_URL=http://127.0.0.1:8013

# 当未配置 HTTP API 或 API 不可用时，Dashboard 会尝试走本地 ClawGraph Store。
# 支持相对路径，路径相对于 `clawgraph/web` 目录解析。
CLAWGRAPH_STORE_URI=../../tmp-bootstrap.db
CLAWGRAPH_PYTHON_BIN=python3
