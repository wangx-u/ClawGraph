{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawgraph.dev/schemas/v1/artifact.schema.json",
  "title": "ClawGraph Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "schema_version",
    "artifact_type",
    "target_ref",
    "producer",
    "payload"
  ],
  "properties": {
    "artifact_id": { "type": "string", "minLength": 1 },
    "schema_version": { "type": "string", "const": "v1" },
    "artifact_type": {
      "type": "string",
      "enum": [
        "score",
        "label",
        "ranking",
        "critique",
        "constraint",
        "distillation_target",
        "teacher_signal",
        "lineage"
      ]
    },
    "target_ref": { "type": "string", "minLength": 1 },
    "producer": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "payload": { "type": "object" },
    "metadata": { "type": "object" },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
